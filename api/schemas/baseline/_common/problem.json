{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "api/schemas/_common/problem.json",
  "title": "Problem",
  "description": "RFC 9457 Problem Details with Sovrunn extensions code, requestId, and violations (F12-ERROR-001).",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1,
      "description": "Stable problem type URI (for example urn:sovrunn:problem:validation-failed).",
      "x-sovrunn-field-policy": {
        "classification": "Public",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "adapter", "plugin", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short human-readable title for the failure class.",
      "x-sovrunn-field-policy": {
        "classification": "Public",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "adapter", "plugin", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": false
      }
    },
    "status": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599,
      "description": "HTTP status code associated with this problem.",
      "x-sovrunn-field-policy": {
        "classification": "Public",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "adapter", "plugin", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "detail": {
      "type": "string",
      "description": "Human-readable detail; MUST NOT expose secrets, stack traces, or inaccessible resource existence (F12-ERROR-004).",
      "x-sovrunn-field-policy": {
        "classification": "Customer-visible",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "adapter", "plugin", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "redact",
        "residency": "any",
        "auditRequired": false
      }
    },
    "instance": {
      "type": "string",
      "description": "Optional URI reference identifying this specific occurrence.",
      "x-sovrunn-field-policy": {
        "classification": "Internal",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": false
      }
    },
    "code": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "description": "Stable Sovrunn machine error code (F12-ERROR-003).",
      "x-sovrunn-field-policy": {
        "classification": "Public",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "adapter", "plugin", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "requestId": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque request correlation identifier for observability; MUST NOT embed secrets.",
      "x-sovrunn-field-policy": {
        "classification": "Internal",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "violations": {
      "type": "array",
      "items": {
        "$ref": "violation.json"
      },
      "description": "Bounded list of field-level violations.",
      "x-sovrunn-field-policy": {
        "classification": "Customer-visible",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "adapter", "plugin", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "redact",
        "residency": "any",
        "auditRequired": true
      }
    }
  },
  "required": ["type", "title", "status", "code"],
  "additionalProperties": false
}
