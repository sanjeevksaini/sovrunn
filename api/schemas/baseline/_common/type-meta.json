{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "api/schemas/_common/type-meta.json",
  "title": "TypeMeta",
  "description": "Contract identity for an externally exchanged object (F12-NAMING-001, F12-NAMING-002).",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]([a-z0-9.-]*[a-z0-9])?/(v1alpha1|v1beta1|v1)$",
      "description": "API group and maturity version: <domain>.sovrunn.io/{v1alpha1|v1beta1|v1}.",
      "x-sovrunn-field-policy": {
        "classification": "Public",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "adapter", "plugin", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z][A-Za-z0-9]*$",
      "description": "Singular PascalCase resource kind.",
      "x-sovrunn-field-policy": {
        "classification": "Public",
        "authorizedWriter": "system",
        "authorizedReaders": ["customer", "operator", "internal", "adapter", "plugin", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    }
  },
  "required": ["apiVersion", "kind"],
  "additionalProperties": false
}
