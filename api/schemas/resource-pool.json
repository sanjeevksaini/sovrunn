{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "api/schemas/resource-pool.json",
  "title": "ResourcePool",
  "description": "Operator-facing ManagedResource under Provider scope (Matrix D). Provider-neutral capabilities only; no vendor-native fields.",
  "type": "object",
  "x-sovrunn-profile": "ManagedResource",
  "x-sovrunn-boundary": "operator-facing",
  "x-sovrunn-allowed-scopes": ["Provider"],
  "x-sovrunn-stability": "alpha",
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["fabric.sovrunn.io/v1alpha1"],
      "description": "Contract group and maturity version for ResourcePool.",
      "x-sovrunn-field-policy": {
        "classification": "Public",
        "authorizedWriter": "system",
        "authorizedReaders": ["operator", "internal", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "kind": {
      "type": "string",
      "enum": ["ResourcePool"],
      "description": "Singular PascalCase resource kind.",
      "x-sovrunn-field-policy": {
        "classification": "Public",
        "authorizedWriter": "system",
        "authorizedReaders": ["operator", "internal", "governance"],
        "mutability": "immutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "metadata": {
      "$ref": "_common/object-meta.json",
      "description": "Common ObjectMeta including immutable Provider scopeRef.",
      "x-sovrunn-field-policy": {
        "classification": "Operator-confidential",
        "authorizedWriter": "creator",
        "authorizedReaders": ["operator", "internal", "governance"],
        "mutability": "mutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "spec": {
      "type": "object",
      "description": "Desired provider-neutral pool declaration.",
      "properties": {
        "capabilityClass": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "description": "Provider-neutral capability class (not a vendor SKU).",
          "x-sovrunn-field-policy": {
            "classification": "Operator-confidential",
            "authorizedWriter": "spec-owner",
            "authorizedReaders": ["operator", "internal", "governance"],
            "mutability": "mutable",
            "retention": "standard",
            "redaction": "none",
            "residency": "any",
            "auditRequired": true
          }
        },
        "jurisdictionCode": {
          "type": "string",
          "minLength": 2,
          "maxLength": 16,
          "pattern": "^[A-Z0-9_-]+$",
          "description": "Normalized jurisdiction code for residency/placement; not a cloud-region vendor ID.",
          "x-sovrunn-field-policy": {
            "classification": "Operator-confidential",
            "authorizedWriter": "spec-owner",
            "authorizedReaders": ["operator", "internal", "governance"],
            "mutability": "mutable",
            "retention": "standard",
            "redaction": "none",
            "residency": "restricted",
            "auditRequired": true
          }
        }
      },
      "required": ["capabilityClass"],
      "additionalProperties": false,
      "x-sovrunn-field-policy": {
        "classification": "Operator-confidential",
        "authorizedWriter": "spec-owner",
        "authorizedReaders": ["operator", "internal", "governance"],
        "mutability": "mutable",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    },
    "status": {
      "type": "object",
      "description": "System-owned observed pool state.",
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["Pending", "Ready", "Degraded", "Unavailable", "Deleting", "Failed"],
          "x-sovrunn-field-policy": {
            "classification": "Operator-confidential",
            "authorizedWriter": "status-owner",
            "authorizedReaders": ["operator", "internal", "governance"],
            "mutability": "system-only",
            "retention": "standard",
            "redaction": "none",
            "residency": "any",
            "auditRequired": true
          }
        },
        "observedGeneration": {
          "type": "integer",
          "minimum": 0,
          "x-sovrunn-field-policy": {
            "classification": "Internal",
            "authorizedWriter": "status-owner",
            "authorizedReaders": ["operator", "internal", "governance"],
            "mutability": "system-only",
            "retention": "standard",
            "redaction": "none",
            "residency": "any",
            "auditRequired": false
          }
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "_common/condition.json"
          },
          "x-sovrunn-field-policy": {
            "classification": "Operator-confidential",
            "authorizedWriter": "status-owner",
            "authorizedReaders": ["operator", "internal", "governance"],
            "mutability": "system-only",
            "retention": "standard",
            "redaction": "redact",
            "residency": "any",
            "auditRequired": true
          }
        }
      },
      "additionalProperties": false,
      "x-sovrunn-field-policy": {
        "classification": "Operator-confidential",
        "authorizedWriter": "status-owner",
        "authorizedReaders": ["operator", "internal", "governance"],
        "mutability": "system-only",
        "retention": "standard",
        "redaction": "none",
        "residency": "any",
        "auditRequired": true
      }
    }
  },
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false
}
